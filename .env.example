# Database — PostgreSQL (Neon, local, or any PG-compatible)
# For local: postgresql://akenga:akenga_local@localhost:5432/akenga
# For Neon:  postgresql://neondb_owner:xxxx@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://akenga:akenga_local@localhost:5432/akenga

# Image Storage — pick one provider below
# Option 1: Local (default — files saved to ./uploads/). No extra config needed.
# Option 2: Cloudinary
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
# CLOUDINARY_UPLOAD_PRESET=akenga

# Option 3: S3-compatible (AWS S3, MinIO, Cloudflare R2, etc.)
# S3_BUCKET=akenga-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_ENDPOINT=https://your-s3-endpoint  # Optional, for non-AWS providers

# When using local storage, set the base URL for uploaded files:
# UPLOAD_BASE_URL=/uploads
